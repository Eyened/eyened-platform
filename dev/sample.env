# environment variables for use with development setup

# ---- API authentication ----
EYENED_API_SECRET_KEY=
EYENED_API_PUBLIC_AUTH_DISABLED=false
EYENED_API_DEBUG=true

# ---- Database (ORM + dev docker) ----
MYSQL_ROOT_PASSWORD=

EYENED_DATABASE_USER=root
EYENED_DATABASE_PASSWORD=${MYSQL_ROOT_PASSWORD}
EYENED_DATABASE_HOST=
EYENED_DATABASE_PORT=


# ---- Dev ports / routing ----
DEV_NGINX_PORT=
DEV_SERVER_PORT=
DEV_FRONTEND_SERVER_PORT=
DEV_ADMINER_PORT=

# Server reads nginx.conf aliases for storage routing
EYENED_ROUTING_CONFIG=dev/nginx.conf

# ---- Optional ----
PYTHON_VENV_PATH=