# Copy to `.env` in this directory. This worker is standalone: point at any reachable Redis and DB.

# --- Redis (RQ broker) — required. Same values as the API uses to enqueue jobs.
EYENED_REDIS_HOST=127.0.0.1
EYENED_REDIS_PORT=6379
EYENED_REDIS_DB=0
EYENED_REDIS_PASSWORD=change_me_to_a_long_random_secret

# --- Database — required for inference tasks (same as API / `eyened_orm` Database()).
# EYENED_DATABASE_USER=
# EYENED_DATABASE_PASSWORD=
# EYENED_DATABASE_HOST=
# EYENED_DATABASE_PORT=3306
# EYENED_DATABASE_DATABASE=

# --- Storage — host path mounted into the container at the same path (inference reads image files).
EYENED_STORAGE_ROOT=/storage

# --- RQ worker queues (comma-separated). See `server.config.RqSettings`.
# Full GPU worker (Dockerfile.worker): e.g. default + all CFI queues, or omit to use server default.
# EYENED_RQ_WORKER_QUEUES=default,cfi-roi,cfi-keypoints,cfi-odfd,cfi-quality,cfi-amd
# If you run the slim ROI worker (`Dockerfile.cfi-roi`), set that service to ``cfi-roi`` only and
# remove ``cfi-roi`` from the GPU worker list so each job is handled once.
# EYENED_RQ_WORKER_QUEUES=default,cfi-keypoints,cfi-odfd,cfi-quality
#
# Dedicated AMD worker:
# EYENED_RQ_WORKER_QUEUES=cfi-amd

# --- API settings (loaded by `server.config`; set if your Settings require them, e.g. secret key).
# EYENED_API_SECRET_KEY=
