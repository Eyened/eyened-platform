# Copy to .env and adjust. Do not commit real secrets.

# --- Redis (RQ job broker) ---
# Required when using the docker-compose `redis` service. Use a long random value.
# If EYENED_REDIS_PUBLISH_PORT is exposed, also use a firewall or VPN; Redis here is password-only (no TLS).
EYENED_REDIS_PASSWORD=change_me_to_a_long_random_secret

# Port on the Docker host mapped to Redis (remote workers connect to host:EYENED_REDIS_PUBLISH_PORT).
EYENED_REDIS_PUBLISH_PORT=6379

# Inside Compose, the server uses hostname `redis` via overrides in docker-compose.yaml.
# For a standalone RQ worker container, see `worker/.env.example` in the repo root.

# Same path as the main `docker-compose.yaml` server volume (inference reads image files here).
EYENED_STORAGE_ROOT=/storage
